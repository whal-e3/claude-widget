{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/v2/crates/tauri-config-schema/schema.json",
  "productName": "Claude Usage Widget",
  "version": "0.1.0",
  "identifier": "com.claude-widget.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage",
        "width": 420,
        "height": 380,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": false,
        "x": null,
        "y": null
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://claude.ai https://*.claude.ai https://api.anthropic.com"
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    },
    "store": null
  }
}
